@model CozyComfort.Client.Models.Order

<h2>Place Order</h2>

<form asp-action="CreateOrder" method="post">

    <div class="form-group">
        <label asp-for="SellerName"></label>
        <input asp-for="SellerName" class="form-control" required />
        <span asp-validation-for="SellerName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="BlanketId"></label>
        <input asp-for="BlanketId" type="number" class="form-control" required />
        <span asp-validation-for="BlanketId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Quantity"></label>
        <input asp-for="Quantity" type="number" class="form-control" required />
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Submit Order</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}