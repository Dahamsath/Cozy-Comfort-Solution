<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cozy Comfort</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CozyComfort.Client.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-blanket"></i> Cozy Comfort
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Home</a>
                        </li>

                        @if (Context.Session.GetString("Username") != null)
                        {
                            var role = Context.Session.GetString("UserRole");
                            var user = Context.Session.GetString("Username");

                            @if (role == "Distributor")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Distributor" asp-action="Index"><i class="fas fa-truck-loading"></i> Distributor Dashboard</a>
                                </li>
                            }
                            else if (role == "Seller")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Seller" asp-action="Index"><i class="fas fa-store"></i> Seller Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="OrderHistory" asp-action="Index"><i class="fas fa-history"></i> My Orders</a>
                                </li>
                            }
                            else if (role == "Client")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Client" asp-action="Index"><i class="fas fa-shopping-bag"></i> Shop Blankets</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Client" asp-action="MyOrders"><i class="fas fa-receipt"></i> My Orders</a>
                                </li>
                            }

                            <li class="nav-item ms-auto">
                                <span class="nav-link text-dark fw-bold">
                                    <i class="fas fa-user-circle"></i> @user
                                    <small class="text-muted">(@role)</small>
                                </span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-area="" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item ms-auto">
                                <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login"><i class="fas fa-sign-in-alt"></i> Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-primary text-white ms-2" asp-area="" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container">
            <p>&copy; @DateTime.Now.Year - Cozy Comfort Supply Chain System. All Rights Reserved.</p>
            <small>Powered by Service-Oriented Architecture (.NET Core)</small>
        </div>
    </footer>

    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>