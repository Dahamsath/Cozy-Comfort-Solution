@model List<CozyComfort.Client.Models.Blanket>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold" style="color: #2c3e50;"><i class="fas fa-box-open"></i> Available Blankets</h2>
    <a asp-action="CreateOrder" class="btn btn-primary"><i class="fas fa-plus-circle"></i> Place New Order</a>
</div>

@if (Model != null && Model.Count > 0)
{
    <div class="table-responsive">
        <table class="table table-hover align-middle shadow-sm bg-white rounded">
            <thead class="table-dark">
                <tr>
                    <th>ID</th> 
                    <th>Model Name</th>
                    <th>Material</th>
                    <th>Price</th>
                    <th>Stock Level</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-muted">#@item.Id</td> 
                        <td class="fw-bold">@item.ModelName</td>
                        <td><span class="badge bg-light text-dark border">@item.Material</span></td>
                        <td class="text-success fw-bold">$@item.Price.ToString("F2")</td>
                        <td>
                            @if (item.StockLevel > 20)
                            {
                                <span class="text-success"><i class="fas fa-check-circle"></i> @item.StockLevel Units</span>
                            }
                            else if (item.StockLevel > 0)
                            {
                                <span class="text-warning"><i class="fas fa-exclamation-triangle"></i> @item.StockLevel Units</span>
                            }
                            else
                            {
                                <span class="text-danger"><i class="fas fa-times-circle"></i> Out of Stock</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="CreateOrder" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Order</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <div class="alert alert-info text-center shadow-sm">
        <i class="fas fa-info-circle"></i> No blankets available at the moment. Please contact the manufacturer.
    </div>
}